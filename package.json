{
  "name": "mkdown",
  "displayName": "mkdown Markdown Editor",
  "description": "A WYSIWYG Markdown Editor for VSCode.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.98.0"
  },
  "publisher": "axshb",
  "repository": {
    "type": "git",
    "url": "https://github.com/axshb/mkdown.git"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "mkdown.editor",
        "displayName": "mkdown Markdown Editor",
        "selector": [
          {
            "filenamePattern": "*.md"
          }
        ],
        "priority": "option"
      }
    ],
    "configuration": {
      "title": "mkdown",
      "properties": {
        "mkdown.theme": {
          "type": "string",
          "enum": [
            "zenith-dark",
            "zenith-light",
            "abcdef",
            "abcdefMergeStyles",
            "applyMergeRevertStyles",
            "abyss",
            "abyssMergeStyles",
            "androidStudio",
            "androidStudioMergeStyles",
            "andromeda",
            "andromedaMergeStyles",
            "basicDark",
            "basicDarkMergeStyles",
            "basicLight",
            "basicLightMergeStyles",
            "catppuccinMocha",
            "catppuccinMochaMergeStyles",
            "cobalt2",
            "cobalt2MergeStyles",
            "forest",
            "forestMergeStyles",
            "githubDark",
            "githubDarkMergeStyles",
            "githubLight",
            "githubLightMergeStyles",
            "gruvboxDark",
            "gruvboxDarkMergeStyles",
            "gruvboxLight",
            "gruvboxLightMergeStyles",
            "highContrastDark",
            "highContrastDarkMergeStyles",
            "highContrastLight",
            "highContrastLightMergeStyles",
            "materialDark",
            "materialDarkMergeStyles",
            "materialLight",
            "materialLightMergeStyles",
            "monokai",
            "monokaiMergeStyles",
            "nord",
            "nordMergeStyles",
            "palenight",
            "palenightMergeStyles",
            "solarizedDark",
            "solarizedDarkMergeStyles",
            "solarizedLight",
            "solarizedLightMergeStyles",
            "synthwave84",
            "synthwave84MergeStyles",
            "tokyoNightDay",
            "tokyoNightDayMergeStyles",
            "tokyoNightStorm",
            "tokyoNightStormMergeStyles",
            "volcano",
            "volcanoMergeStyles",
            "vsCodeDark",
            "vsCodeDarkMergeStyles",
            "vsCodeLight",
            "vsCodeLightMergeStyles"
          ],
          "default": "vsCodeDark",
          "description": "Theme for the markdown editor."
        },
        "mkdown.font.size": {
          "type": "number",
          "default": 16,
          "description": "Font size in pixels."
        },
        "mkdown.font.family": {
          "type": "string",
          "enum": [
            "sans-serif",
            "serif",
            "monospace",
            "Arial",
            "Helvetica",
            "Verdana",
            "Courier New",
            "Georgia",
            "Times New Roman",
            "Consolas",
            "Trebuchet MS"
          ],
          "default": "sans-serif",
          "description": "Font family for the editor."
        },
        "mkdown.layout.alignment": {
          "type": "string",
          "enum": [
            "obsidian",
            "left",
            "center"
          ],
          "enumDescriptions": [
            "Centered content with max-width (like Obsidian)",
            "Content flush left, full width",
            "Content centered, no max-width"
          ],
          "default": "obsidian",
          "description": "Content alignment in the editor."
        },
        "mkdown.highlight.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable dynamic regex-based highlighting."
        },
        "mkdown.highlight.rules": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "pattern": {
                "type": "string",
                "description": "Regex pattern (e.g. '\"[^\"]*\"' for double-quoted text)."
              },
              "color": {
                "type": "string",
                "description": "Hex color for the highlight (e.g. '#f97316')."
              },
              "label": {
                "type": "string",
                "description": "Optional label for this rule."
              }
            },
            "required": [
              "pattern"
            ]
          },
          "default": [
            {
              "pattern": "\"[^\"]*\"",
              "color": "#f97316",
              "label": "Double quotes"
            },
            {
              "pattern": "\\*[^*]+\\*",
              "color": "#808080CC",
              "label": "Italics"
            }
          ],
          "description": "Custom regex rules for dynamic highlighting. Each rule has a pattern, optional color, and optional label."
        },
        "mkdown.selectionToolbar.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show a floating formatting toolbar when text is selected."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack && npm run build:webview",
    "watch": "webpack --watch",
    "package": "npm run build:webview && webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "build:webview": "esbuild ./src/webview-src/main.ts --bundle --outfile=media/webview.dist.js --format=iife",
    "vscode-package": "npx @vscode/vsce package --out mkdown.vsix --no-dependencies"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.98.0",
    "@types/vscode-webview": "^1.57.5",
    "@typescript-eslint/eslint-plugin": "^8.45.0",
    "@typescript-eslint/parser": "^8.45.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.25.11",
    "eslint": "^9.36.0",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "webpack": "^5.102.0",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.19.0",
    "@codemirror/commands": "^6.9.0",
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lang-markdown": "^6.4.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/language": "^6.11.3",
    "@codemirror/language-data": "^6.5.1",
    "@codemirror/lint": "^6.9.0",
    "@codemirror/search": "^6.5.11",
    "@codemirror/state": "^6.5.2",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.38.6",
    "@fsegurai/codemirror-theme-bundle": "^6.3.0",
    "@lezer/highlight": "^1.2.2",
    "@lezer/markdown": "^1.5.1",
    "codemirror": "^6.0.2",
    "isomorphic-dompurify": "^1.0.0",
    "katex": "^0.16.47"
  }
}
